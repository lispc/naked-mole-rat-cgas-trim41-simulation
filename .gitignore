# MD data and trajectories (large binary files)
data/
*.dcd
*.chk
*.rst7
*.nc
*.trr
*.xtc
*.cpt

# Amber/tleap temp files
leap.log
tleap.log
*.inpcrd
*.restrt

# Python cache
__pycache__/
*.pyc
*.pyo

# AF3 raw outputs (large)
structures/af3_raw/*/*.cif
structures/af3_raw/*/*.json
structures/af3_raw/*/msas/
structures/af3_raw/*/templates/

# Docking intermediate files (large, can be regenerated)
structures/docking/lightdock/*/swarm_*/
structures/docking/lightdock/*/init/
structures/docking/lightdock/*/rank_by_*.list
structures/docking/lightdock/*/solutions.list
structures/docking/lightdock/*/*.info
structures/docking/lightdock/*/*.npy
structures/docking/lightdock/*/lightdock_*.pdb
structures/docking/lightdock/*/top_*.pdb

# ClusPro archives
structures/docking/cluspro/*.tar.bz2
structures/docking/cluspro/*/

# Third-party tools
tools/SDOCK2.0/

# OS files
.DS_Store
Thumbs.db

# Editor backups
*~
*.swp
*.swo
